generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Board {
  id      String   @id
  name    String
  data    Json
  records Record[]
}

model Record {
  id      String @id
  boardId String
  data    Json
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
}
